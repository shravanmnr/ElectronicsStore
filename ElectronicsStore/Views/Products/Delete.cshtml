@model ElectronicsStore.Models.Product

@{
    ViewBag.Title = "Delete";
}

<h2>Delete</h2>

<h3>Are you sure you want to delete this?</h3>
<div>
    <h4>Product</h4>
    <hr />
    <dl class="dl-horizontal">
        <dt>Name</dt>
        <dd>@Model.Name</dd>

        <dt>Description</dt>
        <dd>@Model.Description</dd>

        <dt>Price</dt>
        <dd>@Model.Price</dd>

        <dt>Stock</dt>
        <dd>@Model.Stock</dd>

        <dt>Image URL</dt>
        <dd>@Model.ImageUrl</dd>
    </dl>

    @using (Html.BeginForm("Delete", "Products", new { id = Model.Id }, FormMethod.Post))
    {
        @Html.AntiForgeryToken()
        <div class="form-actions no-color">
            <input type="submit" value="Delete" class="btn btn-danger" /> |
            @Html.ActionLink("Back to List", "Index", "Products")
        </div>
    }
</div>
